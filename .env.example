# ============================================
# ArbitraX - Variaveis de Ambiente (template)
# ============================================
# NUNCA commitar este arquivo com valores reais. Copie para .env e preencha.

# ---------- Database (Supabase) ----------
# Pooler (para queries do app). porta 6543 + pgbouncer=true
DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct (para migrations, CREATE EXTENSION, etc). Conexao direta ao db host
DIRECT_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# ---------- Supabase Storage (armazenamento de arquivos) ----------
# Dashboard Supabase -> Project Settings -> API
SUPABASE_URL=https://PROJECT_REF.supabase.co
# service_role key (NAO a anon!). Necessario pro backend criar/baixar arquivos ignorando RLS
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Nome do bucket (sera criado automaticamente no boot se nao existir)
S3_BUCKET=arbitrax-documents

# ---------- JWT ----------
# Gerar com: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_ACCESS_SECRET=replace-with-64-char-random-base64
JWT_REFRESH_SECRET=replace-with-64-char-random-base64
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---------- Certificado Digital A1 ----------
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTEGRATION_ENCRYPTION_KEY=replace-with-64-hex-chars

# ---------- ZapSign (assinatura digital) ----------
ZAPSIGN_API_TOKEN=your-zapsign-api-token
ZAPSIGN_ENV=sandbox

# ---------- Brevo (email transacional) ----------
# Brevo Dashboard -> SMTP & API -> API Keys
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-login-email
SMTP_PASS=your-brevo-smtp-key
SMTP_FROM=noreply@yourdomain.com

# ---------- Asaas ----------
ASAAS_API_KEY=your-asaas-api-key
ASAAS_WEBHOOK_TOKEN=your-asaas-webhook-token
ASAAS_ENV=sandbox

# ---------- AI ----------
OPENAI_API_KEY=your-openai-api-key
AI_PROVIDER=openai
AI_MODEL=gpt-4.1

# ---------- App / CORS ----------
# Multiplos dominios separados por virgula
APP_URL=https://yourdomain.com,https://www.yourdomain.com
API_URL=https://api.yourdomain.com
NODE_ENV=production
PORT=80

# ---------- Frontend (variavel de build do Next.js) ----------
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
