generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ──────────────────────────────────────────

enum UserRole {
  REQUERENTE
  REQUERIDO
  ADVOGADO
  ARBITRO
  ADMIN
}

enum ArbitragemStatus {
  AGUARDANDO_PAGAMENTO_REGISTRO
  AGUARDANDO_ACEITE
  RECUSADA
  AGUARDANDO_ASSINATURA
  AGUARDANDO_PAGAMENTO_TAXA
  EM_INSTRUCAO
  AGUARDANDO_PETICAO
  AGUARDANDO_CONTESTACAO
  ANALISE_PROVAS
  AGUARDANDO_PROVAS_ADICIONAIS
  GERANDO_SENTENCA
  SENTENCA_EM_REVISAO
  SENTENCA_APROVADA
  SENTENCA_RATIFICADA
  ENCERRADA
  CANCELADA
}

enum CategoriaArbitragem {
  COMERCIAL
  CONSUMIDOR
  EMPRESARIAL
  TRABALHISTA
  IMOBILIARIO
  OUTROS
}

enum PecaTipo {
  PETICAO_INICIAL
  CONTESTACAO
  REPLICA
  TREPLICA
  ALEGACOES_FINAIS
  OUTROS
}

enum ProvaTipo {
  DOCUMENTO
  IMAGEM
  VIDEO
  AUDIO
  TESTEMUNHO
  PRINT
}

enum SentencaStatus {
  RASCUNHO
  EM_REVISAO
  APROVADA
  RATIFICADA
  PUBLICADA
}

enum CobrancaTipo {
  REGISTRO
  TAXA_ARBITRAL
  HONORARIOS
  URGENCIA
}

enum CobrancaStatus {
  PENDENTE
  PAGO
  VENCIDO
  CANCELADO
  REEMBOLSADO
}

enum PrazoTipo {
  ACEITE
  ASSINATURA
  PETICAO
  CONTESTACAO
  PROVAS_ADICIONAIS
  REVISAO_SENTENCA
  RATIFICACAO
  CUSTOM
}

enum PrazoStatus {
  ATIVO
  CUMPRIDO
  EXPIRADO
  CANCELADO
}

// ─── Models ─────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  nome      String
  cpfCnpj   String   @unique @map("cpf_cnpj")
  email     String   @unique
  telefone  String   @unique
  senhaHash String   @map("senha_hash")
  role      UserRole
  oabNumero String?  @map("oab_numero")
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 2FA (TOTP)
  twoFactorSecret  String?  @map("two_factor_secret")
  twoFactorEnabled Boolean  @default(false) @map("two_factor_enabled")

  // Certificado Digital A1
  certificadoA1Base64      String?   @map("certificado_a1_base64") @db.Text
  certificadoA1Senha       String?   @map("certificado_a1_senha")
  certificadoA1Cn          String?   @map("certificado_a1_cn")
  certificadoA1Emissor     String?   @map("certificado_a1_emissor")
  certificadoA1Validade    DateTime? @map("certificado_a1_validade")
  certificadoA1Serial      String?   @map("certificado_a1_serial")
  certificadoA1AtualizadoEm DateTime? @map("certificado_a1_atualizado_em")

  // Relations
  arbitragensRequerente  Arbitragem[]        @relation("Requerente")
  arbitragensRequerido   Arbitragem[]        @relation("Requerido")
  arbitragensAdvReq      Arbitragem[]        @relation("AdvRequerente")
  arbitragensAdvReqdo    Arbitragem[]        @relation("AdvRequerido")
  arbitragemArbitros     ArbitragemArbitro[]
  pecas                  Peca[]
  provas                 Prova[]
  sentencaAprovacoes     SentencaAprovacao[]
  prazos                 Prazo[]
  cobrancas              Cobranca[]
  chatMessages           ChatMessage[]
  notificacoes           Notificacao[]
  assinatura             Assinatura?
  auditLogs              AuditLog[]

  @@index([role, telefone])
  @@map("users")
}

model TipoDemanda {
  id         String              @id @default(uuid())
  nome       String              @unique
  categoria  CategoriaArbitragem
  ativo      Boolean             @default(true)
  createdAt  DateTime            @default(now()) @map("created_at")
  arbitragens Arbitragem[]
  @@map("tipos_demanda")
}

model Arbitragem {
  id               String             @id @default(uuid())
  numero           String             @unique
  requerenteId     String             @map("requerente_id")
  requeridoId      String?            @map("requerido_id")
  advRequerenteId  String?            @map("adv_requerente_id")
  advRequeridoId   String?            @map("adv_requerido_id")
  objeto           String
  valorCausa       Decimal            @db.Decimal(12, 2) @map("valor_causa")
  categoria        CategoriaArbitragem
  urgencia         Boolean            @default(false)
  tipoDemandaId    String?            @map("tipo_demanda_id")
  regraLeis        Boolean            @default(true) @map("regra_leis")
  regraEquidade    Boolean            @default(false) @map("regra_equidade")
  regraCostumes    Boolean            @default(false) @map("regra_costumes")
  modoArbitro      String?            @map("modo_arbitro")
  status           ArbitragemStatus   @default(AGUARDANDO_PAGAMENTO_REGISTRO)
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  // Relations
  tipoDemanda      TipoDemanda?       @relation(fields: [tipoDemandaId], references: [id])
  requerente       User               @relation("Requerente", fields: [requerenteId], references: [id])
  requerido        User?              @relation("Requerido", fields: [requeridoId], references: [id])
  advRequerente    User?              @relation("AdvRequerente", fields: [advRequerenteId], references: [id])
  advRequerido     User?              @relation("AdvRequerido", fields: [advRequeridoId], references: [id])
  arbitros         ArbitragemArbitro[]
  compromisso      Compromisso?
  pecas            Peca[]
  provas           Prova[]
  sentencas        Sentenca[]
  prazos           Prazo[]
  cobrancas        Cobranca[]
  chatMessages     ChatMessage[]
  convite          Convite?

  @@index([status, createdAt])
  @@map("arbitragens")
}

model ArbitragemArbitro {
  id            String   @id @default(uuid())
  arbitragemId  String   @map("arbitragem_id")
  arbitroId     String   @map("arbitro_id")
  status        String   @default("designado")
  designadoAt   DateTime @default(now()) @map("designado_at")

  arbitragem    Arbitragem @relation(fields: [arbitragemId], references: [id])
  arbitro       User       @relation(fields: [arbitroId], references: [id])

  @@unique([arbitragemId, arbitroId])
  @@map("arbitragem_arbitros")
}

model Compromisso {
  id            String   @id @default(uuid())
  arbitragemId  String   @unique @map("arbitragem_id")
  pdfUrl        String?  @map("pdf_url")
  hashSha256    String?  @map("hash_sha256")
  clicksignKey  String?  @map("clicksign_key")
  assinReqAt        DateTime? @map("assin_req_at")
  assinReqdoAt      DateTime? @map("assin_reqdo_at")
  assinaturaReqCn   String?   @map("assinatura_req_cn")
  assinaturaReqdoCn String?   @map("assinatura_reqdo_cn")
  status            String    @default("pendente")
  createdAt         DateTime  @default(now()) @map("created_at")

  arbitragem    Arbitragem @relation(fields: [arbitragemId], references: [id])

  @@map("compromissos")
}

model Peca {
  id            String   @id @default(uuid())
  arbitragemId  String   @map("arbitragem_id")
  autorId       String   @map("autor_id")
  tipo          PecaTipo
  conteudo      String?
  anexos        String[] @default([])
  protocoladaAt DateTime @default(now()) @map("protocolada_at")

  arbitragem    Arbitragem @relation(fields: [arbitragemId], references: [id])
  autor         User       @relation(fields: [autorId], references: [id])

  @@index([arbitragemId, tipo])
  @@map("pecas")
}

model Prova {
  id            String    @id @default(uuid())
  arbitragemId  String    @map("arbitragem_id")
  parteId       String    @map("parte_id")
  tipo          ProvaTipo
  descricao     String?
  arquivoUrl    String    @map("arquivo_url")
  hashSha256    String    @map("hash_sha256")
  mimeType      String?   @map("mime_type")
  tamanho       Int?
  createdAt     DateTime  @default(now()) @map("created_at")

  arbitragem    Arbitragem @relation(fields: [arbitragemId], references: [id])
  parte         User       @relation(fields: [parteId], references: [id])

  @@index([arbitragemId, tipo])
  @@map("provas")
}

model Sentenca {
  id             String          @id @default(uuid())
  arbitragemId   String          @map("arbitragem_id")
  versao         Int             @default(1)
  conteudoTexto  String          @map("conteudo_texto")
  pdfUrl         String?         @map("pdf_url")
  hashSha256     String?         @map("hash_sha256")
  assinadoDigitalmenteAt   DateTime? @map("assinado_digitalmente_at")
  assinadoDigitalmentePor  String?   @map("assinado_digitalmente_por")
  certificadoCn            String?   @map("certificado_cn")
  codigoVerif    String?         @unique @map("codigo_verif")
  status         SentencaStatus  @default(RASCUNHO)
  geradaPor      String          @map("gerada_por")
  createdAt      DateTime        @default(now()) @map("created_at")

  arbitragem     Arbitragem          @relation(fields: [arbitragemId], references: [id])
  aprovacoes     SentencaAprovacao[]

  @@unique([arbitragemId, versao])
  @@map("sentencas")
}

model SentencaAprovacao {
  id             String   @id @default(uuid())
  sentencaId     String   @map("sentenca_id")
  arbitroId      String   @map("arbitro_id")
  acao           String   // aprovar | sugerir | ratificar
  sugestoesTexto String?  @map("sugestoes_texto")
  createdAt      DateTime @default(now()) @map("created_at")

  sentenca       Sentenca @relation(fields: [sentencaId], references: [id])
  arbitro        User     @relation(fields: [arbitroId], references: [id])

  @@unique([sentencaId, arbitroId, acao])
  @@map("sentenca_aprovacoes")
}

model Prazo {
  id            String      @id @default(uuid())
  arbitragemId  String      @map("arbitragem_id")
  tipo          PrazoTipo
  parteId       String?     @map("parte_id")
  inicio        DateTime    @default(now())
  fim           DateTime
  status        PrazoStatus @default(ATIVO)
  notificado3d  Boolean     @default(false) @map("notificado_3d")
  notificado1d  Boolean     @default(false) @map("notificado_1d")
  notificadoExp Boolean     @default(false) @map("notificado_exp")
  createdAt     DateTime    @default(now()) @map("created_at")

  arbitragem    Arbitragem @relation(fields: [arbitragemId], references: [id])
  parte         User?      @relation(fields: [parteId], references: [id])

  @@index([status, fim])
  @@map("prazos")
}

model Cobranca {
  id            String        @id @default(uuid())
  arbitragemId  String        @map("arbitragem_id")
  pagadorId     String        @map("pagador_id")
  tipo          CobrancaTipo
  valor         Decimal       @db.Decimal(12, 2)
  status        CobrancaStatus @default(PENDENTE)
  gatewayId     String?       @map("gateway_id")
  pixQrcode     String?       @map("pix_qrcode")
  boletoUrl     String?       @map("boleto_url")
  vencimento    DateTime
  pagoAt        DateTime?     @map("pago_at")
  createdAt     DateTime      @default(now()) @map("created_at")

  arbitragem    Arbitragem @relation(fields: [arbitragemId], references: [id])
  pagador       User       @relation(fields: [pagadorId], references: [id])

  @@index([arbitragemId, status])
  @@map("cobrancas")
}

// ─── Chat Interno (substitui WhatsApp) ──────────────

model ChatMessage {
  id            String   @id @default(uuid())
  arbitragemId  String   @map("arbitragem_id")
  userId        String   @map("user_id")
  tipo          String   @default("text") // text | document | image | video | audio | system
  conteudo      String?
  mediaUrl      String?  @map("media_url")
  lida          Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at")

  arbitragem    Arbitragem @relation(fields: [arbitragemId], references: [id])
  user          User       @relation(fields: [userId], references: [id])

  @@index([arbitragemId, createdAt])
  @@map("chat_messages")
}

// ─── Convites ───────────────────────────────────────

model Convite {
  id            String   @id @default(uuid())
  arbitragemId  String   @unique @map("arbitragem_id")
  token         String   @unique @default(uuid())
  status        String   @default("pendente") // pendente | aceito | recusado | expirado
  enviadoAt     DateTime @default(now()) @map("enviado_at")
  respondidoAt  DateTime? @map("respondido_at")
  expiracaoAt   DateTime @map("expiracao_at")

  arbitragem    Arbitragem @relation(fields: [arbitragemId], references: [id])

  @@map("convites")
}

// ─── Planos e Assinaturas ───────────────────────────

model Plano {
  id                  String   @id @default(uuid())
  nome                String   @unique // free | basic | plus | pro | enterprise
  label               String   // Gratuito | Basic | Plus | Pro | Enterprise
  preco               Decimal  @db.Decimal(10, 2) @default(0)
  arbitragensMes      Int      @map("arbitragens_mes") // -1 = ilimitado
  valorMaxCausa       Decimal  @db.Decimal(12, 2) @map("valor_max_causa")
  escolherArbitro     Boolean  @default(false) @map("escolher_arbitro")
  urgenciaDisponivel  Boolean  @default(false) @map("urgencia_disponivel")
  prioridadeFila      Int      @default(0) @map("prioridade_fila") // 0=normal, 1=media, 2=alta
  ativo               Boolean  @default(true)
  createdAt           DateTime @default(now()) @map("created_at")

  assinaturas         Assinatura[]

  @@map("planos")
}

model Assinatura {
  id            String    @id @default(uuid())
  userId        String    @unique @map("user_id")
  planoId       String    @map("plano_id")
  status        String    @default("ativa") // ativa | cancelada | expirada
  usadoMes      Int       @default(0) @map("usado_mes")
  inicioAt      DateTime  @default(now()) @map("inicio_at")
  renovacaoAt   DateTime? @map("renovacao_at")
  canceladoAt   DateTime? @map("cancelado_at")

  user          User   @relation(fields: [userId], references: [id])
  plano         Plano  @relation(fields: [planoId], references: [id])

  @@map("assinaturas")
}

model Notificacao {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  titulo    String
  mensagem  String
  tipo      String   // prazo | sentenca | pagamento | sistema
  lida      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now()) @map("created_at")

  user      User @relation(fields: [userId], references: [id])

  @@index([userId, lida])
  @@map("notificacoes")
}

model Template {
  id        String   @id @default(uuid())
  tipo      String   // compromisso | sentenca
  nome      String
  conteudo  String
  variaveis String[] @default([])
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("templates")
}

model IaPrompt {
  id              String  @id @default(uuid())
  tipo            String  // analise_provas | gerar_sentenca | refinar_sentenca | resumo
  modelo          String  @default("gpt-4o")
  promptSistema   String  @map("prompt_sistema")
  promptTemplate  String  @map("prompt_template")
  temperatura     Float   @default(0.3)
  ativo           Boolean @default(true)

  @@map("ia_prompts")
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  acao        String
  entidade    String
  entidadeId  String?  @map("entidade_id")
  dadosAntes  Json?    @map("dados_antes")
  dadosDepois Json?    @map("dados_depois")
  ip          String?
  createdAt   DateTime @default(now()) @map("created_at")

  user        User? @relation(fields: [userId], references: [id])

  @@index([entidade, entidadeId])
  @@map("audit_logs")
}
